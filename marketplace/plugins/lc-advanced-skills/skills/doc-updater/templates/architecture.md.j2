## System Topology

```mermaid
graph TB
    subgraph Sources["Data Sources"]
{% if sensors.edr %}
        EDR["EDR Sensors ({{ sensors.edr_count }})"]
{% endif %}
{% if sensors.cloud %}
        CLOUD["Cloud Sensors ({{ sensors.cloud_count }})"]
{% endif %}
        WH["Webhook Ingestion"]
    end

    subgraph Platform["LimaCharlie Platform"]
        subgraph Engine["D&R Engine"]
{% for cat_name, cat_rules in rules.categories.items() %}
{% set cat_display = cat_rules[0].display_name if cat_rules else cat_name %}
            {{ cat_name | upper }}["{{ cat_display }}<br/>{{ cat_rules | length }} rules"]
{% endfor %}
        end

{% if managed_packs %}
        subgraph Managed["Managed Rule Packs"]
{% for pack in managed_packs %}
            {{ pack.extension | replace('-', '_') | upper }}["{{ pack.name }}"]
{% endfor %}
        end
{% endif %}

        subgraph Data["Data Services"]
            LKP["Lookups ({{ lookups | length }})"]
            PAY["Payloads ({{ payloads | length }})"]
        end
    end

    subgraph AI["AI Agent Layer"]
{% for team_key, team in agents.teams.items() %}
        {{ team_key | upper }}["{{ team.display_name }}<br/>{{ team.agents | length }} agents"]
{% endfor %}
{% if agents.standalone %}
        STANDALONE["Standalone<br/>{{ agents.standalone | length }} agents"]
{% endif %}
    end

    subgraph Outputs["Outputs & Integrations"]
        CASES["ext-cases"]
{% for output in outputs %}
        OUT_{{ loop.index }}["{{ output.name }}<br/>({{ output.module }})"]
{% endfor %}
    end

    Sources --> Engine
{% if managed_packs %}
    Managed --> Engine
{% endif %}
    Engine --> AI
    Engine --> Outputs
    AI --> CASES
    Data --> Engine
```

